treebeard() {
  local TREEBEARD_DIR="$HOME/.treebeard"
  local cmd="${1}"

  case "$cmd" in
    new)
      local name="$2"
      if [ -z "$name" ]; then
        echo "Usage: treebeard new <name>" >&2
        return 1
      fi

      local repo
      repo=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)")
      if [ -z "$repo" ]; then
        echo "Error: not in a git repository" >&2
        return 1
      fi

      local worktree_path="$TREEBEARD_DIR/$repo/$name"
      mkdir -p "$(dirname "$worktree_path")"
      git worktree add "$worktree_path" -b "$name"
      echo "Created worktree at $worktree_path"
      ;;

    list)
      if [ ! -d "$TREEBEARD_DIR" ]; then
        echo "No worktrees found"
        return 0
      fi

      local found=0
      local dirs
      dirs=$(find "$TREEBEARD_DIR" -mindepth 2 -maxdepth 2 -type d | sort)
      if [ -n "$dirs" ]; then
        found=1
        while IFS= read -r dir; do
          echo "${dir#"$TREEBEARD_DIR/"}"
        done <<< "$dirs"
      fi

      if [ "$found" -eq 0 ]; then
        echo "No worktrees found"
      fi
      ;;

    cd)
      local target="$2"
      if [ -z "$target" ]; then
        echo "Usage: treebeard cd <repo>/<name>" >&2
        return 1
      fi

      local worktree_path="$TREEBEARD_DIR/$target"
      if [ ! -d "$worktree_path" ]; then
        echo "Error: worktree not found: $target" >&2
        return 1
      fi

      cd "$worktree_path"
      ;;

    cp)
      local target="$2"
      local file="$3"
      if [ -z "$target" ] || [ -z "$file" ]; then
        echo "Usage: treebeard cp <repo>/<name> <file>" >&2
        return 1
      fi

      local worktree_path="$TREEBEARD_DIR/$target"
      if [ ! -d "$worktree_path" ]; then
        echo "Error: worktree not found: $target" >&2
        return 1
      fi

      cp "$file" "$worktree_path/"
      ;;

    mv)
      local target="$2"
      local file="$3"
      if [ -z "$target" ] || [ -z "$file" ]; then
        echo "Usage: treebeard mv <repo>/<name> <file>" >&2
        return 1
      fi

      local worktree_path="$TREEBEARD_DIR/$target"
      if [ ! -d "$worktree_path" ]; then
        echo "Error: worktree not found: $target" >&2
        return 1
      fi

      mv "$file" "$worktree_path/"
      ;;

    prune)
      local main_branch="${2:-}"

      if [ ! -d "$TREEBEARD_DIR" ]; then
        echo "No worktrees found"
        return 0
      fi

      local dirs
      dirs=$(find "$TREEBEARD_DIR" -mindepth 2 -maxdepth 2 -type d | sort)
      if [ -z "$dirs" ]; then
        echo "No worktrees found"
        return 0
      fi

      while IFS= read -r worktree_path; do
        local target="${worktree_path#"$TREEBEARD_DIR/"}"

        local branch
        branch=$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [ -z "$branch" ]; then
          continue
        fi

        local resolved_main="$main_branch"
        if [ -z "$resolved_main" ]; then
          if git -C "$worktree_path" rev-parse --verify main &>/dev/null; then
            resolved_main="main"
          elif git -C "$worktree_path" rev-parse --verify master &>/dev/null; then
            resolved_main="master"
          else
            echo "Skipping $target: could not determine main branch"
            continue
          fi
        fi

        if git -C "$worktree_path" branch --merged "$resolved_main" 2>/dev/null | grep -q "^[* ]*${branch}$"; then
          local git_common_dir
          git_common_dir=$(git -C "$worktree_path" rev-parse --git-common-dir)
          git worktree remove "$worktree_path" --force
          rmdir "$(dirname "$worktree_path")" 2>/dev/null || true
          git --git-dir="$git_common_dir" branch -d "$branch" 2>/dev/null || true
          echo "Pruned $target (merged into $resolved_main)"
        fi
      done <<< "$dirs"
      ;;

    rm)
      local target="$2"
      if [ -z "$target" ]; then
        echo "Usage: treebeard rm <repo>/<name>" >&2
        return 1
      fi

      local worktree_path="$TREEBEARD_DIR/$target"
      if [ ! -d "$worktree_path" ]; then
        echo "Error: worktree not found: $target" >&2
        return 1
      fi

      local branch
      branch=$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2>/dev/null)

      git worktree remove "$worktree_path" --force
      rmdir "$(dirname "$worktree_path")" 2>/dev/null || true

      if [ -n "$branch" ]; then
        git branch -d "$branch" 2>/dev/null || true
      fi

      echo "Removed worktree $target"
      ;;

    *)
      echo '     \o/  *  \o/'
      echo '      | /^^^\ |'
      echo '      ( | | | )'
      echo '       \|___|/'
      echo '        |   |'
      echo '       /     \'
      echo '      /       \'
      echo ''
      echo '  "Do not be hasty."'
      echo ''
      echo "Usage: treebeard <new|list|cd|cp|mv|rm|prune>" >&2
      echo ""
      echo "Commands:"
      echo "  new <name>              Create a new worktree for the current git repo"
      echo "  list                    List all recorded worktrees"
      echo "  cd <repo>/<name>        cd into a worktree"
      echo "  cp <repo>/<name> <file> Copy a file into a worktree"
      echo "  mv <repo>/<name> <file> Move a file into a worktree"
      echo "  rm <repo>/<name>        Remove a worktree and delete its branch"
      echo "  prune [main-branch]     Remove all worktrees whose branch is merged into main/master"
      return 1
      ;;
  esac
}
